PORT=4173
ADMIN_TOKEN=replace-me-before-deploying
# Use {file} where the staged contribution JSON path belongs.
# Example only; match this to the walrus CLI invocation already used by the prototype.
WALRUS_WRITE_COMMAND=walrus store --epochs 5 {file}
# Optional full command used to write the newly generated room-head JSON.
WALRUS_HEAD_WRITE_COMMAND=walrus store --epochs 5 {file}
# Optional dedicated command for the shared Prediction DNA profile index.
WALRUS_DNA_INDEX_WRITE_COMMAND=walrus store --epochs 5 {file}
WALRUS_AGGREGATOR=https://aggregator.walrus-mainnet.walrus.space
AUTO_PUBLISH_DNA=false
AUTO_PUBLISH_ROOM=true
MAINNET_PUBLISH_ENABLED=false
MIN_WORLD_CUP_POSITIONS=1
MIN_RESOLVED_PREDICTIONS=0
MAX_DAILY_PUBLISHES=25
DNA_REQUEST_COOLDOWN_MINUTES=10

# Optional resident Memory Room agents. Keep the key server-side only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
RESIDENT_AGENT_CACHE_MINUTES=15
# Optional HTTP classifier. It receives { message, allowedTypes } and returns { type }.
MEMORY_CLASSIFIER_URL=
MEMORY_CLASSIFIER_TOKEN=
